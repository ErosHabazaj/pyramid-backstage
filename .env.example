# Copy to .env.local and fill in to enable persistence + realtime.
# The app runs fully on seed data without these.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Claude API key is used ONLY server-side (Supabase Edge Function),
# never exposed to the browser. Do not put it in a VITE_ var.
# ANTHROPIC_API_KEY=
